# =============================================================================
# Boorie - Environment Configuration
# =============================================================================

# Database Configuration (Required)
# PostgreSQL connection string
DATABASE_URL=postgresql://username:password@localhost:5432/dbname

# =============================================================================
# Mapbox Configuration (Required for network visualization)
# =============================================================================
# Get your access token from https://account.mapbox.com/
VITE_MAPBOX_ACCESS_TOKEN=your_mapbox_access_token_here

# Optional: Default map center coordinates
VITE_DEFAULT_MAP_LNG=-70.9
VITE_DEFAULT_MAP_LAT=42.35
VITE_DEFAULT_MAP_ZOOM=9

# =============================================================================
# Microsoft Clarity Analytics (Optional)
# =============================================================================
VITE_CLARITY_PROJECT_ID=ts4zpakpjj
VITE_CLARITY_ENABLED=true

# =============================================================================
# Python/WNTR Configuration (Optional - auto-configured by setup script)
# =============================================================================
# Path to Python executable with WNTR installed
# Leave empty if using ./setup-python-wntr.sh (auto-configured)
# PYTHON_PATH=/path/to/python/with/wntr

# =============================================================================
# Performance Configuration (Optional)
# =============================================================================
# Enable/disable hardware acceleration (default: true)
# Set to false if experiencing crashes or display issues
ENABLE_HARDWARE_ACCELERATION=true
